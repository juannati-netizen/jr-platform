APP_NAME=JR Platform API
APP_ENV=development
APP_VERSION=0.3.0
POSTGRES_DB=jr_platform
POSTGRES_USER=jr_platform
POSTGRES_PASSWORD=jr_platform
DATABASE_URL=postgresql+psycopg://jr_platform:jr_platform@db:5432/jr_platform
JWT_SECRET_KEY=change-this-development-secret-with-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
INITIAL_ADMIN_EMAIL=admin@jrplatform.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!
INITIAL_ADMIN_FULL_NAME=JR Platform Admin
CORS_ORIGINS=http://localhost:5173
